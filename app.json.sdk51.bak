{
  "expo": {
    "name": "We Limin'",
    "slug": "lime-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f5f0e8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.welimin.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f5f0e8"
      },
      "package": "com.welimin.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "We Limin' needs access to your photos to add memories to the scrapbook."
        }
      ]
    ],
    "scheme": "lime-app",
    "experiments": {
      "typedRoutes": true
    }
  }
}
